{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Собрать GUI проект",
            "command": "D:/msys64/mingw64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/*.cpp", 
                "-o", "${fileDirname}/${fileBasenameNoExtension}.exe",
                "-I${workspaceFolder}",
                "-ID:/msys64/mingw64/include/wx-3.2",
                "-ID:/msys64/mingw64/lib/wx/include/msw-unicode-3.2",
                "-LD:/msys64/mingw64/lib",
                "-lwx_mswu_core-3.2",
                "-lwx_baseu-3.2",
                "-lsqlite3"
            ],
            "options": { "cwd": "D:/msys64/mingw64/bin" },
            "group": { "kind": "build", "isDefault": true }
        }
    ]
}